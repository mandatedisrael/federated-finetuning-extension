# FFE live E2E configuration

# Contributor wallets (must be funded with OG for live session + submit txs)
FFE_LIVE_WALLET_1=0x...
FFE_LIVE_WALLET_2=0x...

# EVM private key for aggregator wallet (must start with 0x)
AGG_EVM_KEY=0x...

# X25519 private key for decrypting contributor blobs (32-byte hex, no 0x prefix)
AGG_X25519_KEY=...

# Coordinator contract address on 0G mainnet
COORDINATOR_ADDRESS=0x840C3E83A5f3430079Aff7247CD957c994076015

# INFTMinter contract address on 0G mainnet
INFT_ADDRESS=0xEcEd8069b33Ce4F397e4Df1cbb4cDD2fAA038471

# Optional: 0G mainnet RPC URL (defaults to https://evmrpc.0g.ai)
RPC_URL=https://evmrpc.0g.ai
FT_RPC_URL=https://evmrpc.0g.ai

# Optional: 0G Storage indexer URL (defaults to https://indexer-storage-testnet-turbo.0g.ai)
STORAGE_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai

# Optional: 0G fine-tuning provider address
FT_PROVIDER_ADDRESS=0x940b4a101CaBa9be04b16A7363cafa29C1660B0d

# pnpm demo is real-only and forces USE_REAL_0G_TRAINING=true
USE_REAL_0G_TRAINING=true
BASE_MODEL=Qwen2.5-0.5B-Instruct
TRAINING_TIMEOUT_MS=3600000
DEMO_TIMEOUT_MS=1800000
MAX_CONCURRENT_SESSIONS=1
FFE_LOCAL_STORAGE_DIR=/tmp/ffe-storage

# Optional: Poll interval for QuorumReached events in milliseconds (default: 5000)
POLL_INTERVAL_MS=5000
