{
  "name": "@notmartin/ffe",
  "version": "0.1.0",
  "description": "Federated Fine-tuning Extension — multi-party fine-tuning on 0G",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "FFE_LIVE=1 vitest run",
    "test:live:storage": "FFE_LIVE_STORAGE=1 vitest run test/live/storage.live.test.ts",
    "test:live:open": "FFE_LIVE_OPEN=1 vitest run test/live/ffe.live.test.ts",
    "test:live:submit": "FFE_LIVE_SUBMIT=1 vitest run test/live/submit.live.test.ts",
    "test:live:download": "FFE_LIVE_DOWNLOAD=1 vitest run test/live/download.live.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "abi:sync": "bash scripts/sync-abi.sh"
  },
  "dependencies": {
    "@0gfoundation/0g-ts-sdk": "^1.2.6",
    "@noble/ciphers": "^1.0.0",
    "@noble/curves": "^1.6.0",
    "@noble/hashes": "^1.5.0",
    "ethers": "^6.13.1",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
