# Privy App ID — get one at https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID=

# Invite email delivery. When unset, invite emails render as preview deliveries
# and are not sent to recipients.
RESEND_API_KEY=
EMAIL_FROM="FFE <invites@example.com>"
EMAIL_REPLY_TO=

# Live FFE bridge. These stay server-side in Next API routes.
# FFE_SERVER_PRIVATE_KEY can reuse AGG_EVM_KEY for a single-machine demo.
FFE_SERVER_PRIVATE_KEY=
COORDINATOR_ADDRESS=
INFT_ADDRESS=
RPC_URL=https://evmrpc.0g.ai
STORAGE_EVM_RPC=https://evmrpc.0g.ai
STORAGE_INDEXER_URL=https://indexer-storage-turbo.0g.ai
FFE_BASE_MODEL=Qwen/Qwen2.5-0.5B

# Set the aggregator public key directly, or let the API route derive it from AGG_X25519_KEY.
FFE_AGGREGATOR_X25519_PUBLIC_KEY=
AGG_X25519_KEY=

# Optional local fallback when 0G Storage is unavailable in dev.
FFE_LOCAL_STORAGE_DIR=/tmp/ffe-storage
